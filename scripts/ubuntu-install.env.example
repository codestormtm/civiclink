# Optional override file for scripts/install-ubuntu-server.sh
# Copy this to scripts/ubuntu-install.env and edit the values you need.

SERVER_HOST=your.server.ip.or.domain

DB_USER=civic
DB_PASSWORD=civic123
DB_NAME=civiclink
DB_PORT=5433

BACKEND_PORT=5002
PUBLIC_PORT=5173
ADMIN_PORT=5174
WORKER_PORT=5175
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

ADMIN_NAME=System Admin
ADMIN_EMAIL=sysadmin@civiclink.local
ADMIN_PASSWORD=ChangeMe123!

MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=civiclink

# Optional AI key
GROQ_API_KEY=

# Optional Firebase Admin server credentials
FIREBASE_SERVICE_ACCOUNT_FILE=/absolute/path/to/firebase-service-account.json
# Or set these instead of FIREBASE_SERVICE_ACCOUNT_FILE:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional Firebase Web client values for the citizen portal
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
